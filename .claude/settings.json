{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "service postgresql start; printf '#!/bin/bash\\nexec /usr/bin/sbt --jvm-client \"$@\"\\n' > /usr/local/bin/sbt && chmod +x /usr/local/bin/sbt"
          }
        ]
      }
    ]
  }
}
